== Elaboration ==
raw:
( let M =
    ( 5 : float[G] )
    in
    ( let loop =
          ( rec loop i =>
                ( fun x =>
                      ( if ( ( i : float[G] ) <= ( M : float[G] ) : bool )
                            then
                            ( let y =
                                  ( uniform( ( 0 : float[G] ), ( 1 : float[G] ) ) : float[G] )
                                  in
                                  ( let _ =
                                        ( observe( ( ( y : float[G] ) <= ( 0.5 : float[G] ) : bool ) ) : unit )
                                        in
                                        ( ( loop : float[G] ->  float[?m5] ->  float[?m5] ) ( ( ( i : float[G] ) + ( 1 : float[G] ) :
                                                    float[G] ) ) ( ( ( x : float[?m5] ) + ( y : float[?m5] ) : float[?m5] ) ) : float[?m5] )
                                        : float[?m5] ) : float[?m5] )
                            else
                            ( x : float[?m5] ) : float[?m5] ) : float[?m5] ->  float[?m5] ) : float[G] ->  float[?m5] ->  float[?m5] )
          in
          ( ( loop : float[G] ->  float[?m5] ->  float[?m5] ) ( 1 : float[G] ) ( 0 : float[?m5] ) : float[?m5] ) : float[?m5] ) : float[?m5]
)
