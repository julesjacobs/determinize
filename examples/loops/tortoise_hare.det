( rec loop h =>
    fun t =>
      fun count =>
        if h <= t then
          let h1 =
            if flip(0.5) then
              let x = 10 * uniform(0,1) in
              h + x
            else
              h
          in
          let t1 = t + 1 in
          let count1 = count + 1 in
          loop h1 t1 count1
        else
          count ) 0 5 0
